<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.launchhub.ui.controller.FavoritesController">
    
    <!-- Top Action Bar -->
    <top>
        <VBox spacing="15.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label text="Favorite Applications" styleClass="page-title" />
                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                    <StackPane alignment="CENTER_RIGHT" prefWidth="320.0">
                        <TextField fx:id="searchField" promptText="Search favorites..." styleClass="search-field" prefWidth="320.0" style="-fx-padding: 11px 35px 11px 18px;" />
                        <Button fx:id="btnClearSearch" text="✕" styleClass="clear-search-btn" focusTraversable="false" visible="false">
                            <StackPane.margin>
                                <Insets right="10.0" />
                            </StackPane.margin>
                        </Button>
                    </StackPane>
                </HBox>
            </HBox>
        </VBox>
    </top>
    
    <!-- Main Content Area -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" hbarPolicy="NEVER">
            <FlowPane fx:id="appsGrid" hgap="15.0" vgap="15.0" prefWrapLength="800.0">
                <padding>
                    <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
                </padding>
            </FlowPane>
        </ScrollPane>
    </center>
</BorderPane>
