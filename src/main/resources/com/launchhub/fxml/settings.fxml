<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.launchhub.ui.controller.SettingsController"
      spacing="30.0">
    
    <Label text="Settings" styleClass="page-title" />

    <GridPane hgap="20.0" vgap="25.0" styleClass="dialog-container" style="-fx-padding: 30px;">
        <padding>
            <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
        </padding>

        <!-- Row 0: Theme Selection -->
        <Label text="Interface Theme:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
        <ComboBox fx:id="comboTheme" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <!-- Row 1: Grid Size Adjustment -->
        <Label text="Card Layout Size:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
        <ComboBox fx:id="comboGridSize" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <!-- Row 2: Auto Scan on Startup -->
        <Label text="Startup Library Scan:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
        <CheckBox fx:id="checkAutoScan" text="Automatically scan for changes on launch" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <!-- Row 3: Force Re-scan -->
        <Label text="Maintenance:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
        <Button fx:id="btnResetCache" text="Clear Library &amp; Re-scan" styleClass="button-primary" style="-fx-background-color: #ef4444;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
    </GridPane>

    <VBox spacing="10.0" style="-fx-padding: 20px;" styleClass="dialog-container">
        <Label text="About OrbitApps" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
        <Label text="Version 1.0.0" style="-fx-text-fill: -fx-text-muted;" />
        <Label text="OrbitApps is a desktop game-library styled dashboard designed to scan, classify, and track all executable applications installed on Windows systems." style="-fx-text-fill: -fx-text-secondary;" wrapText="true" />
    </VBox>
</VBox>
